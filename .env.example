# Claude API key — get from https://console.anthropic.com
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Resend API key — get from https://resend.com (free tier works)
RESEND_API_KEY=your_resend_api_key_here

# Email address that sends follow-up emails to vendors
FROM_EMAIL=onboarding@yourdomain.com

# SQLite database file path (no changes needed for local dev)
DATABASE_URL="file:./dev.db"
