# OpenRouter API key — free at https://openrouter.ai/keys
OPENROUTER_API_KEY=your_openrouter_api_key_here

# AI model to use (default: free Llama 3.1 8B)
# Other free options: mistralai/mistral-7b-instruct:free, google/gemma-2-9b-it:free
AI_MODEL=meta-llama/llama-3.1-8b-instruct:free

# Resend API key — get from https://resend.com (optional — app works without it)
RESEND_API_KEY=

# Email address that sends follow-up emails to vendors
FROM_EMAIL=onboarding@yourdomain.com

# PostgreSQL connection string (Render provides this automatically)
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Port (Render sets this automatically)
PORT=4000
