# Gemini API key — free at https://aistudio.google.com → "Get API key"
GEMINI_API_KEY=your_gemini_api_key_here

# Resend API key — get from https://resend.com (optional — app works without it)
RESEND_API_KEY=

# Email address that sends follow-up emails to vendors
FROM_EMAIL=onboarding@yourdomain.com

# PostgreSQL connection string (Railway provides this automatically)
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Port the API server listens on (Railway sets this automatically)
PORT=4000
